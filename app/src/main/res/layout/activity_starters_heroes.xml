<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/title"
    android:orientation="vertical"
    tools:context=".Category.CastlesStarters.HeroesCastle.castle.loynis.JebusStarterHeroLoynisActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="100sp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginVertical="15dp"
        android:fontFamily="@font/bradleytypeprohv"
        android:gravity="center"
        android:text="Heroes of Might and Magic 3: Horn of the Abyss"
        android:textColor="#dbb769"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="15dp"
        android:fontFamily="@font/averia_libre_bold"
        android:gravity="center"
        android:text="Справочник"
        android:textColor="#dbb769"
        android:textSize="28sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30sp"
        app:cardCornerRadius="15dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120sp"
            android:background="@drawable/background_hero"
            android:scaleType="fitXY" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/hero_image"
                android:layout_width="70sp"
                android:layout_height="70sp"
                android:layout_gravity="center"
                android:layout_marginStart="15sp"
                android:src="@drawable/hero_loynis" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25sp"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="50sp"
                        android:layout_height="50sp"
                        android:layout_marginHorizontal="5sp"
                        android:src="@drawable/attack_skill" />

                    <ImageView
                        android:id="@+id/hero_image3"
                        android:layout_width="50sp"
                        android:layout_height="50sp"
                        android:layout_marginHorizontal="5sp"
                        android:src="@drawable/defense_skill" />

                    <ImageView
                        android:id="@+id/hero_image4"
                        android:layout_width="50sp"
                        android:layout_height="50sp"
                        android:layout_marginHorizontal="5sp"
                        android:src="@drawable/power_skill" />

                    <ImageView
                        android:id="@+id/hero_image5"
                        android:layout_width="50sp"
                        android:layout_height="50sp"
                        android:layout_marginHorizontal="5sp"
                        android:src="@drawable/knowledge_skill" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/attack_skill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="25sp"
                        android:layout_marginTop="5sp"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/defense_skill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="25sp"
                        android:layout_marginTop="5sp"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/power_skill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="25sp"
                        android:layout_marginTop="5sp"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/knowledge_skill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="25sp"
                        android:layout_marginTop="5sp"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="20sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30sp"
        android:layout_marginTop="10sp"
        app:cardCornerRadius="15dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120sp"
            android:background="@drawable/background_hero"
            android:scaleType="fitXY" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30sp"
            android:layout_marginTop="5sp"
            android:fontFamily="@font/averia_libre_bold"
            android:gravity="center"
            android:text="Вторичные навыки:"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/hero_skill_image1"
                    android:layout_width="55sp"
                    android:layout_height="55sp"
                    android:layout_gravity="center"
                    android:layout_marginStart="15sp"
                    android:src="@drawable/basic_wisdom" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="55sp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginLeft="5sp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="Базовый"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/hero_skill_name1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10sp"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="Мудрость"
                        android:textColor="@color/white"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="right"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/hero_skill_image2"
                    android:layout_width="55sp"
                    android:layout_height="55sp"
                    android:layout_gravity="center"
                    android:layout_marginStart="15sp"
                    android:src="@drawable/basic_learning" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="55sp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="15sp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="Базовый"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/hero_skill_name2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10sp"
                        android:fontFamily="@font/averia_libre_bold"
                        android:text="Обучаемость"
                        android:textColor="@color/white"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>


    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30sp"
        android:layout_marginTop="10sp"
        app:cardCornerRadius="15dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120sp"
            android:background="@drawable/background_hero"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/special_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10sp"
            android:layout_marginTop="5sp"
            android:fontFamily="@font/averia_libre_bold"
            android:gravity="center"
            android:text="Специализация: Молитва"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/special_image"
                android:layout_width="55sp"
                android:layout_height="55sp"
                android:layout_gravity="center"
                android:layout_marginStart="15sp"
                android:src="@drawable/specialty_prayer" />

            <TextView
                android:id="@+id/special_description"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="10sp"
                android:layout_marginBottom="20sp"
                android:layout_marginTop="30sp"
                android:fontFamily="@font/averia_libre_bold"
                android:gravity="center"
                android:text="Увеличивает эффективность заклинания
Молитва на 3 для существ 1-4 уровня,
на 2 для существ 5-6уровня
и на 1 для существ 7 уровня."
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30sp"
        android:layout_marginTop="10sp"
        app:cardCornerRadius="15dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120sp"
            android:background="@drawable/background_hero"
            android:scaleType="fitXY" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30sp"
            android:layout_marginTop="5sp"
            android:fontFamily="@font/averia_libre_bold"
            android:gravity="center"
            android:text="Стартовая армия:"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/creature_image1"
                android:layout_width="55sp"
                android:layout_height="55sp"
                android:layout_gravity="center"
                android:layout_marginStart="10sp"
                android:src="@drawable/pikeman_portrait" />

            <TextView
                android:id="@+id/creature_name1"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="5sp"
                android:fontFamily="@font/averia_libre_bold"
                android:gravity="center_vertical"
                android:text="10-20"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/creature_image2"
                android:layout_width="55sp"
                android:layout_height="55sp"
                android:layout_gravity="center"
                android:layout_marginStart="10sp"
                android:src="@drawable/archer_portrait" />

            <TextView
                android:id="@+id/creature_name2"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="5sp"
                android:fontFamily="@font/averia_libre_bold"
                android:gravity="center_vertical"
                android:text="4-7"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/creature_image3"
                android:layout_width="55sp"
                android:layout_height="55sp"
                android:layout_gravity="center"
                android:layout_marginStart="10sp"
                android:src="@drawable/griffin_portrait" />

            <TextView
                android:id="@+id/creature_name3"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="5sp"
                android:fontFamily="@font/averia_libre_bold"
                android:gravity="center_vertical"
                android:text="4-5"
                android:textColor="@color/white"
                android:textSize="16sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>


</LinearLayout>
